# Public origin used by Better Auth redirects and cookies.
BETTER_AUTH_URL=https://algodrill.example.com

# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# One-time owner setup token. Generate with: openssl rand -base64 32
SETUP_TOKEN=

# Optional bearer token for unattended weekly export consumers.
# Generate with: openssl rand -base64 48
EXPORT_API_TOKEN=
EXPORT_API_USER_EMAIL=

# SQLite database path inside the app container.
DATABASE_PATH=/data/algodrill.sqlite

# S3-compatible Litestream target.
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
